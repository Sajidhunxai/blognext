// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  password  String
  name      String?
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  posts     Post[]
}

model Category {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  name         String   @unique
  slug         String   @unique
  description  String?
  featured     Boolean  @default(false) // Featured categories for homepage
  posts        Post[]
  translations CategoryTranslation[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Post {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  title           String
  content         String
  slug            String   @unique
  published       Boolean  @default(false)
  authorId        String   @db.ObjectId
  author          User     @relation(fields: [authorId], references: [id])
  categoryId      String?  @db.ObjectId
  category        Category? @relation(fields: [categoryId], references: [id])
  allowComments   Boolean  @default(true)
  
  // SEO Fields
  metaTitle       String?
  metaDescription String?
  keywords        String[]
  focusKeyword    String?   // Target keyphrase for SEO (e.g. "best android game")
  noIndex         Boolean   @default(false) // Exclude from search engine indexing
  faqs            Json?     // [{ question: string, answer: string }] for FAQ schema & section
  ogImage         String?
  ogImageAlt      String?
  featuredImage   String?
  featuredImageAlt String?
  screenshots     String[]  @default([]) // App screenshots (URLs) displayed under featured image
  downloadLink    String?
  
  // App Details
  developer       String?
  appSize         String?
  appVersion      String?
  requirements    String?
  downloads       String?
  googlePlayLink  String?
  
  // Rating
  rating          Float?   // Rating from 0.0 to 5.0
  ratingCount     Int      @default(0) // Number of ratings/reviews
  
  comments        Comment[]
  rankChecks      RankCheck[]
  translations    PostTranslation[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Page {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  title           String
  content         String
  slug            String   @unique
  published       Boolean  @default(true)
  
  // SEO Fields
  metaTitle       String?
  metaDescription String?
  featuredImage   String?
  featuredImageAlt String?
  
  translations    PageTranslation[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Comment {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  postId      String   @db.ObjectId
  post        Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorName  String
  authorEmail String
  authorWebsite String?
  content     String
  approved    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Settings {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  siteName        String   @default("Blog CMS")
  logo            String?
  darkModeLogo    String?  // Logo for dark mode
  favicon         String?
  
  // Header Navigation
  headerMenu      Json?    // Array of menu items: [{ label: "Home", url: "/" }, { label: "About", url: "/pages/about" }] or ["Home", "Apps"] for backward compatibility
  
  // Footer Links
  footerLinks     Json?    // Array of footer link items: [{ label: "About", url: "/pages/about" }] or ["About"] for backward compatibility
  
  // Social Media Links
  socialMedia     Json?    // { facebook: "", twitter: "", instagram: "", youtube: "", pinterest: "", telegram: "" }
  
  // Hero Section
  heroTitle       String?
  heroSubtitle    String?
  heroBackground  String?
  
  // SEO Fields for Homepage
  metaTitle       String?  // Meta title for homepage (separate from hero title)
  metaDescription String?  // Meta description for homepage (separate from hero subtitle)
  
  // Why Choose Us Section
  whyChooseTitle       String?  // Title for "Why Choose Us" section
  whyChooseSubtitle    String?  // Subtitle/description for "Why Choose Us" section
  whyChooseFeatures    Json?    // Array of feature objects: [{ icon: "phone", title: "Latest Apps", description: "..." }, ...]
  
  // Comments
  enableComments  Boolean  @default(true)
  
  // Theme Colors
  primaryColor       String?  @default("#dc2626") // Red
  secondaryColor     String?  @default("#16a34a") // Green
  backgroundColor    String?  @default("#111827") // Dark gray
  textColor          String?  @default("#ffffff") // White
  buttonColor        String?  @default("#dc2626") // Primary button
  buttonTextColor    String?  @default("#ffffff") // Button text color
  linkColor          String?  @default("#3b82f6") // Blue links
  successColor       String?  @default("#16a34a") // Green success
  errorColor         String?  @default("#dc2626") // Red error
  warningColor       String?  @default("#f59e0b") // Orange warning
  infoColor          String?  @default("#3b82f6") // Blue info
  
  // Dark Mode Colors
  darkModeBackgroundColor  String?  @default("#0a0a0a") // Dark mode background
  darkModeTextColor        String?  @default("#ededed") // Dark mode text
  
  
  // Custom Scripts and CSS
  headerScript       String?  // Scripts to add in <head>
  footerScript       String?  // Scripts to add before </body>
  headerCSS          String?  // CSS to add in <head>
  footerCSS          String?  // CSS to add before </body>
  
  translations       SettingsTranslation[]
  updatedAt          DateTime @updatedAt
}

model Redirect {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  from        String   @unique // Source path/URL (e.g., "/old-page" or "/old-post")
  to          String   // Destination URL (can be relative like "/new-page" or absolute like "https://example.com")
  type        Int      @default(301) // Redirect type: 301 (permanent) or 302 (temporary)
  active      Boolean  @default(true) // Whether the redirect is active
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model RankCheck {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  keyword     String   // The keyword being ranked
  postId      String?  @db.ObjectId // Optional reference to Post
  post        Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  siteUrl     String   // The URL to check ranking for (e.g., your site domain)
  ranking     Int?     // The position in search results (null if not found)
  checkedAt   DateTime @default(now()) // When the rank was checked
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([keyword])
  @@index([postId])
  @@index([checkedAt])
}

// ============ Translation models for i18n (en, ur, hi) ============

model PostTranslation {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  postId          String   @db.ObjectId
  post            Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  locale          String   // "ur" | "hi" (English is source in Post)
  title           String
  content         String
  metaTitle       String?
  metaDescription String?
  keywords        String[]
  focusKeyword    String?
  faqs            Json?    // [{ question: string, answer: string }]
  ogImageAlt      String?
  featuredImageAlt String?
  developer       String?
  requirements    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([postId, locale])
  @@index([postId])
  @@index([locale])
}

model PageTranslation {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  pageId          String   @db.ObjectId
  page            Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  locale          String
  title           String
  content         String
  metaTitle       String?
  metaDescription String?
  featuredImageAlt String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([pageId, locale])
  @@index([pageId])
  @@index([locale])
}

model CategoryTranslation {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  categoryId  String   @db.ObjectId
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  locale      String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([categoryId, locale])
  @@index([categoryId])
  @@index([locale])
}

model SettingsTranslation {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  settingsId         String   @db.ObjectId
  settings           Settings @relation(fields: [settingsId], references: [id], onDelete: Cascade)
  locale             String
  siteName           String?
  heroTitle          String?
  heroSubtitle       String?
  metaTitle          String?
  metaDescription    String?
  whyChooseTitle     String?
  whyChooseSubtitle  String?
  whyChooseFeatures  Json?    // Translated feature array
  headerMenu         Json?    // Translated menu items
  footerLinks        Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([settingsId, locale])
  @@index([settingsId])
  @@index([locale])
}

